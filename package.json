    "genshin-db": "latest",
    "mathjs": "^12.0.0",
    "mongodb": "3.6",
    "mongoose": "^8.0.0",
    "pino": "^8.17.0",
    "redis": "^4.6.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
